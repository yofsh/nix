#!/usr/bin/env python3
"""Emit one JSON status line per second over a single long-lived process.

Consumed by quickshell's network popup. Covers wifi link (iw), ethernet
link (/sys/class/net), tailscale status, default gateway, and DNS.

Usage:
    qs-net-status            # loop, 1s cadence, line-buffered JSON to stdout
    qs-net-status --once     # single JSON line and exit (debugging)
"""

import json
import os
import re
import subprocess
import sys
import time


def run(cmd, timeout=2):
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return r.stdout
    except (subprocess.CalledProcessError, FileNotFoundError, subprocess.TimeoutExpired):
        return ""


def list_ifaces():
    try:
        return sorted(os.listdir("/sys/class/net"))
    except OSError:
        return []


def find_wiface():
    for n in list_ifaces():
        if n.startswith("wl"):
            return n
    return ""


def find_eiface():
    for n in list_ifaces():
        if n.startswith(("eth", "enp", "eno", "ens")) and not n.startswith("enp0s"):
            return n
    # fallback to anything that starts with these prefixes
    for n in list_ifaces():
        if n.startswith(("eth", "enp", "eno", "ens")):
            return n
    return ""


def read_iface_file(iface, name):
    try:
        with open(f"/sys/class/net/{iface}/{name}") as f:
            return f.read().strip()
    except OSError:
        return ""


def parse_wifi(iface):
    """Return wifi dict matching wifi-info script fields."""
    if not iface:
        return None
    link = run(["iw", "dev", iface, "link"])
    if not link.strip() or "Not connected" in link:
        return {"connected": False, "iface": iface}

    station = run(["iw", "dev", iface, "station", "dump"])
    info = run(["iw", "dev", iface, "info"])

    def search(pat, src, group=1, cast=None):
        m = re.search(pat, src)
        if not m:
            return None
        v = m.group(group)
        if cast:
            try:
                return cast(v)
            except (ValueError, TypeError):
                return None
        return v

    out = {
        "connected": True,
        "iface": iface,
        "ssid": search(r"SSID: (.+)", link) or "",
        "bssid": search(r"Connected to ([0-9a-f:]{17})", link) or "",
        "freq": search(r"freq: ([\d.]+)", link, cast=float) or 0.0,
        "signal_dbm": search(r"signal: (-?\d+)", link, cast=int),
        "rx_bytes": search(r"RX: (\d+) bytes", link, cast=int) or 0,
        "tx_bytes": search(r"TX: (\d+) bytes", link, cast=int) or 0,
        "tx_mbps": 0.0,
        "rx_mbps": 0.0,
        "tx_mod": "",
        "rx_mod": "",
        "channel": "",
        "width": "",
        "txpower": "",
        "signal_avg_dbm": search(r"signal avg:\s*(-?\d+)", station, cast=int),
        "tx_retries": search(r"tx retries:\s*(\d+)", station, cast=int) or 0,
        "tx_packets": search(r"tx packets:\s*(\d+)", station, cast=int) or 0,
        "tx_failed": search(r"tx failed:\s*(\d+)", station, cast=int) or 0,
        "beacon_loss": search(r"beacon loss:\s*(\d+)", station, cast=int) or 0,
        "connected_time": search(r"connected time:\s*(\d+)", station, cast=int) or 0,
    }

    m = re.search(r"tx bitrate: ([\d.]+) (M|G)Bit/s\s*(.*)", link, re.IGNORECASE)
    if m:
        out["tx_mbps"] = float(m.group(1)) * (1000.0 if m.group(2).lower() == "g" else 1.0)
        out["tx_mod"] = m.group(3).strip()
    m = re.search(r"rx bitrate: ([\d.]+) (M|G)Bit/s\s*(.*)", link, re.IGNORECASE)
    if m:
        out["rx_mbps"] = float(m.group(1)) * (1000.0 if m.group(2).lower() == "g" else 1.0)
        out["rx_mod"] = m.group(3).strip()

    m = re.search(r"channel (\d+) \([\d.]+ MHz\), width: (\d+ MHz)", info)
    if m:
        out["channel"] = m.group(1)
        out["width"] = m.group(2)
    m = re.search(r"txpower ([\d.]+) dBm", info)
    if m:
        out["txpower"] = m.group(1)

    # Wi-Fi generation hint
    tx_mod = out["tx_mod"]
    freq = out["freq"]
    if "EHT" in tx_mod:
        out["gen"] = "7"
    elif "HE" in tx_mod:
        out["gen"] = "6E" if freq >= 5925 else "6"
    elif "VHT" in tx_mod:
        out["gen"] = "5"
    elif "MCS" in tx_mod:
        out["gen"] = "4"
    else:
        out["gen"] = "?"

    if freq >= 5925:
        out["band"] = "6 GHz"
    elif freq >= 5000:
        out["band"] = "5 GHz"
    elif freq > 0:
        out["band"] = "2.4 GHz"
    else:
        out["band"] = ""

    # MLO detection
    out["mlo"] = bool(re.search(r"^MLD |Link \d+ BSSID", link, re.MULTILINE))

    out["ip"] = ipv4_for(iface)
    return out


def parse_ethernet(iface):
    if not iface:
        return None
    op = read_iface_file(iface, "operstate")
    speed_raw = read_iface_file(iface, "speed")
    duplex = read_iface_file(iface, "duplex")
    mac = read_iface_file(iface, "address")
    rx = read_iface_file(iface, "statistics/rx_bytes")
    tx = read_iface_file(iface, "statistics/tx_bytes")

    try:
        speed = int(speed_raw)
    except (TypeError, ValueError):
        speed = 0

    return {
        "connected": op == "up",
        "iface": iface,
        "operstate": op,
        "speed_mbps": speed,
        "duplex": duplex,
        "mac": mac,
        "ip": ipv4_for(iface),
        "rx_bytes": int(rx) if rx.isdigit() else 0,
        "tx_bytes": int(tx) if tx.isdigit() else 0,
    }


def ipv4_for(iface):
    out = run(["ip", "-4", "-o", "addr", "show", "dev", iface])
    m = re.search(r"inet (\d+\.\d+\.\d+\.\d+)", out)
    return m.group(1) if m else ""


def parse_gateway():
    out = run(["ip", "route", "get", "1.1.1.1"])
    gw = re.search(r"via (\S+)", out)
    dev = re.search(r"dev (\S+)", out)
    src = re.search(r"src (\S+)", out)
    return {
        "gateway": gw.group(1) if gw else "",
        "dev": dev.group(1) if dev else "",
        "src": src.group(1) if src else "",
    }


def parse_resolvectl_dns():
    """Return {iface: [dns_servers]} from systemd-resolved.

    `resolvectl dns` output:
        Global:
        Link 3 (wlp109s0): 192.168.8.30
        Link 2 (enp113s0): 192.168.8.30 1.1.1.1
    """
    raw = run(["resolvectl", "dns"], timeout=1)
    if not raw:
        return {}
    out = {}
    for line in raw.splitlines():
        m = re.match(r"\s*Link\s+\d+\s+\(([^)]+)\):\s*(.*)$", line)
        if m:
            servers = m.group(2).strip().split()
            out[m.group(1)] = servers
        elif line.startswith("Global:"):
            servers = line.split(":", 1)[1].strip().split()
            if servers:
                out["__global__"] = servers
    return out


def parse_nmcli_dns(iface):
    """NetworkManager-reported IPv4 DNS for an iface. Used when resolvectl
    isn't useful (no systemd-resolved)."""
    raw = run(["nmcli", "-g", "IP4.DNS", "device", "show", iface], timeout=1)
    return [s for s in raw.replace("|", " ").split() if s]


def parse_resolv_conf():
    """Last-resort fallback. On systemd-resolved this is the stub
    (127.0.0.53), which is rarely what the user wants — hence why we
    prefer resolvectl / nmcli first."""
    servers = []
    try:
        with open("/etc/resolv.conf") as f:
            for line in f:
                m = re.match(r"\s*nameserver\s+(\S+)", line)
                if m:
                    servers.append(m.group(1))
    except OSError:
        pass
    return servers


def dns_for(iface, resolvectl_map):
    """Pick the upstream DNS for a given interface."""
    if not iface:
        return []
    if iface in resolvectl_map and resolvectl_map[iface]:
        return resolvectl_map[iface][:4]
    nm = parse_nmcli_dns(iface)
    if nm:
        return nm[:4]
    return []


def parse_tailscale():
    raw = run(["tailscale", "status", "--json"], timeout=2)
    if not raw.strip():
        return {"installed": False}

    try:
        data = json.loads(raw)
    except json.JSONDecodeError:
        return {"installed": True, "state": "error"}

    state = data.get("BackendState", "Unknown")
    self_node = data.get("Self") or {}
    ips = data.get("TailscaleIPs") or self_node.get("TailscaleIPs") or []

    peers = data.get("Peer") or {}
    peer_total = len(peers)
    peer_online = sum(1 for p in peers.values() if p.get("Online"))
    exit_node = ""
    for p in peers.values():
        if p.get("ExitNode"):
            exit_node = p.get("HostName") or p.get("DNSName") or ""
            break

    health = data.get("Health") or []

    return {
        "installed": True,
        "state": state,
        "running": state == "Running",
        "hostname": self_node.get("HostName") or "",
        "dns_name": (self_node.get("DNSName") or "").rstrip("."),
        "ips": ips,
        "exit_node": exit_node,
        "peer_total": peer_total,
        "peer_online": peer_online,
        "health": health,
        "magic_dns": data.get("MagicDNSSuffix", ""),
    }


def collect():
    wiface = find_wiface()
    eiface = find_eiface()
    resolvectl = parse_resolvectl_dns()

    wifi = parse_wifi(wiface) if wiface else None
    if wifi:
        wifi["dns"] = dns_for(wiface, resolvectl)

    ethernet = parse_ethernet(eiface) if eiface else None
    if ethernet:
        ethernet["dns"] = dns_for(eiface, resolvectl)

    gateway = parse_gateway()
    # Effective system DNS = whichever DNS the default-route iface uses.
    # Falls back to resolvectl global or /etc/resolv.conf as a last resort.
    sys_dns = dns_for(gateway.get("dev"), resolvectl)
    if not sys_dns:
        sys_dns = resolvectl.get("__global__", [])[:4]
    if not sys_dns:
        sys_dns = parse_resolv_conf()[:4]

    return {
        "ts": time.time(),
        "gateway": gateway,
        "dns": sys_dns,
        "wifi": wifi,
        "ethernet": ethernet,
        "tailscale": parse_tailscale(),
    }


def main():
    once = "--once" in sys.argv
    interval = 1.0

    if once:
        print(json.dumps(collect()), flush=True)
        return

    while True:
        start = time.monotonic()
        try:
            print(json.dumps(collect()), flush=True)
        except BrokenPipeError:
            return
        except Exception as e:
            print(json.dumps({"error": str(e), "ts": time.time()}), flush=True)
        elapsed = time.monotonic() - start
        time.sleep(max(0.05, interval - elapsed))


if __name__ == "__main__":
    main()
