#!/usr/bin/env zsh

# title → role mapping
typeset -A title_to_role=(
  ["YouTube Music — Mozilla Firefox"]="music"
  ["Home Overview – Home Assistant — Mozilla Firefox"]="ha"
  ["Extension: (Bitwarden Password Manager) - Bitwarden — Mozilla Firefox"]="bw"
  ["Open WebUI — Mozilla Firefox"]="gpt"
)

# role → managed window address
typeset -A managed=()

# role → setup function
setup_music()  { pseudo_resize "$1" "1740" "1368"; move_workspace "$1" "music" }
setup_ha()     { floating "$1"; resize "$1" "1740" "95%"; center "$1"; move_workspace "$1" "ha"; center "$1" }
setup_bw()     { floating "$1"; resize "$1" "400" "600"; center "$1" }
setup_gpt()    { floating "$1"; resize "$1" "1740" "95%"; center "$1"; move_workspace "$1" "gpt"; center "$1" }

run() {
  local label="$1"; shift
  local result
  result=$("$@" 2>&1)
  if [[ "$result" == "ok" ]]; then
    echo "  ✅ $label"
  else
    echo "  ❌ $label — $result"
  fi
}

# Lua dispatch helper — escapes Lua expression for shell
ldispatch() {
  hyprctl dispatch "$1"
}

floating()       { run "float"            ldispatch "hl.dsp.window.float({ action = \"set\", window = \"$1\" })" }
tiled()          { run "tile"             ldispatch "hl.dsp.window.float({ action = \"unset\", window = \"$1\" })" }
move_workspace() { run "move → $2"        ldispatch "hl.dsp.window.move({ workspace = \"special:$2\", follow = false, window = \"$1\" })" }
center()         { run "center"           ldispatch "hl.dsp.window.center({ window = \"$1\" })" }

# Resolve a "1740" or "95%" value against a monitor's logical (scaled) dimension.
# $1 = value, $2 = axis ("w" or "h"), $3 = window address
resolve_dim() {
  local value="$1" axis="$2" win="$3"
  if [[ "$value" == *% ]]; then
    local pct="${value%\%}"
    local field; [[ "$axis" == "w" ]] && field="width" || field="height"
    local mon
    mon=$(hyprctl clients -j | jq -r --arg a "${win#address:}" '.[] | select(.address == $a) | .monitor')
    hyprctl monitors -j | jq -r --arg m "$mon" --arg f "$field" --arg p "$pct" \
      '.[] | select(.id == ($m|tonumber)) | (.[$f] / .scale * ($p|tonumber) / 100 | floor)'
  else
    echo "$value"
  fi
}

resize() {
  local window="$1" w="$2" h="$3"
  local wpx hpx
  wpx=$(resolve_dim "$w" w "$window")
  hpx=$(resolve_dim "$h" h "$window")
  run "resize ${w}x${h}" ldispatch "hl.dsp.window.resize({ x = $wpx, y = $hpx, relative = false, window = \"$window\" })"
}

is_pseudo() {
  local addr="${1#address:}"
  hyprctl clients -j | jq -r --arg a "$addr" '.[] | select(.address == $a) | .pseudo' 2>/dev/null
}

pseudo() {
  local window="$1" state="${2:-on}"
  local current
  current=$(is_pseudo "$window")
  if [[ "$state" == "on" && "$current" == "true" ]] || \
     [[ "$state" == "off" && "$current" == "false" ]]; then
    echo "  ⏭️  pseudo already $state"
    return
  fi
  local action; [[ "$state" == "on" ]] && action="set" || action="unset"
  run "pseudo $state" ldispatch "hl.dsp.window.pseudo({ action = \"$action\", window = \"$window\" })"
}

pseudo_resize() {
  local window="$1" w="$2" h="$3"
  floating "$window"
  resize "$window" "$w" "$h"
  tiled "$window"
  pseudo "$window" on
}

# check if a managed window still exists
window_exists() {
  local addr="${1#address:}"
  hyprctl clients -j | jq -e --arg a "$addr" '.[] | select(.address == $a)' &>/dev/null
}

# clean up stale managed entries
cleanup_managed() {
  for role addr in "${(@kv)managed}"; do
    if ! window_exists "$addr"; then
      echo "🧹 [$role] window $addr gone, unmanaging"
      unset "managed[$role]"
    fi
  done
}

handle_window() {
  IFS='>' read -r event rest <<< "$1"

  # handle window close — remove from managed
  if [[ "$event" == "closewindow" ]]; then
    local closed="address:0x${rest:1}"
    for role addr in "${(@kv)managed}"; do
      if [[ "$addr" == "$closed" ]]; then
        echo "🚪 [$role] closed ($closed)"
        unset "managed[$role]"
        return
      fi
    done
    return
  fi

  [[ "$event" != "windowtitlev2" ]] && return

  IFS=',' read -r address title <<< "$rest"
  local window="address:0x${address:1}"

  local role="${title_to_role[$title]}"
  [[ -z "$role" ]] && return

  # already managed by this address — nothing to do
  if [[ "${managed[$role]}" == "$window" ]]; then
    return
  fi

  # another window already manages this role — skip
  if [[ -n "${managed[$role]}" ]]; then
    if window_exists "${managed[$role]}"; then
      echo "⏭️  [$role] already managed by ${managed[$role]}, skipping $window"
      return
    fi
    # stale entry, clean up
    unset "managed[$role]"
  fi

  echo "🆕 [$role] claiming $window"
  managed[$role]="$window"
  setup_${role} "$window"
  echo ""
}

socat -u "UNIX-CONNECT:$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock" STDOUT | while read -r line; do
  handle_window "$line"
done
