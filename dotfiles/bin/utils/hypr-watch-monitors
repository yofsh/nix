#!/bin/sh

# When an external monitor is plugged in, pull workspaces 1-6 back onto it.
# Monitor name must match the value of $screen in hyprland.lua.
SCREEN="DP-3"

handle() {
	case $1 in monitoradded*)
		for ws in 1 2 3 4 5 6; do
			hyprctl dispatch "hl.dsp.workspace.move({ workspace = \"$ws\", monitor = \"$SCREEN\" })"
		done
		;;
	esac
}

socat -u "UNIX-CONNECT:$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock" STDOUT | while read -r line; do handle "$line"; done
