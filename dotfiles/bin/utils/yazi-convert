#!/usr/bin/env bash
# Convert images to JPEG, scale to max 2K, strip EXIF
# Supports archives (zip, tar.gz, rar, 7z) — extracts images first
# Usage: yazi-convert <name> <file|archive>...

set -euo pipefail

. "$(dirname "$(readlink -f "$0")")/../lib/archive.sh"

name="${1:-}"
shift

if [ $# -eq 0 ]; then
	echo "No files specified" >&2
	exit 1
fi

dir="$(dirname "$1")"
files=()
tmpdir=""
archive=""

# Strip all extensions from archive name (e.g. photos.tar.gz -> photos)
archive_stem() {
	local base
	base="$(basename "$1")"
	base="${base%%.*}"
	echo "$base"
}

if [ $# -eq 1 ] && is_archive "$1"; then
	archive="$1"
	tmpdir="$(mktemp -d)"
	echo "Extracting $(basename "$archive")..."
	extract_archive "$archive" "$tmpdir"

	# Collect image files from extracted contents
	while IFS= read -r -d '' f; do
		files+=("$f")
	done < <(find_images "$tmpdir")

	if [ ${#files[@]} -eq 0 ]; then
		echo "No images found in archive" >&2
		rm -rf "$tmpdir"
		exit 1
	fi

	if [ -z "$name" ]; then
		name="$(archive_stem "$archive")"
	fi

	echo "Found ${#files[@]} image(s)"
	echo
else
	# Regular image files
	for f in "$@"; do
		files+=("$f")
	done

	if [ -z "$name" ]; then
		# Use first file's name without extension as default
		name="$(basename "${files[0]}")"
		name="${name%.*}"
	fi
fi

outdir="$dir/$name"
mkdir -p "$outdir"

total=${#files[@]}
echo "Converting $total image(s) → $outdir/"
echo "Output: ${name}_001.jpg, ${name}_002.jpg, ..."
echo

count=0
for f in "${files[@]}"; do
	count=$((count + 1))
	out="$outdir/${name}_$(printf '%03d' $count).jpg"
	echo "[$count/$total] $(basename "$f") → $(basename "$out")"
	magick "$f" -resize '2560x2560>' -strip -quality 90 "$out"
done

echo
echo "Done. $count image(s) saved to $outdir/"

# Clean up temp dir from archive extraction
if [ -n "$tmpdir" ]; then
	rm -rf "$tmpdir"
fi

printf "\nDelete original files? [y/N] "
read -r answer
if [[ "$answer" =~ ^[Yy]$ ]]; then
	if command -v trash-put &>/dev/null; then
		del="trash-put"
	else
		del="rm"
	fi
	if [ -n "$archive" ]; then
		$del "$archive"
		echo "Deleted $(basename "$archive")"
	else
		for f in "${files[@]}"; do
			$del "$f"
			echo "Deleted $(basename "$f")"
		done
	fi
fi

notify-send "yazi-convert" "Converted $count image(s) to $outdir"
