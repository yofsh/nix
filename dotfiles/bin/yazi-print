#!/usr/bin/env bash
# Print images / PDFs / archives via CUPS with interactive printer + paper selection.
# Images:  convert to JPEG if needed, print as 4x6 (10x15 cm) glossy by default.
# PDFs:    prompt for page range, send to printer.
# Archives (zip/tar/7z/rar): extract, find images, print each.
#
# Defaults match the working settings established for the Canon G600 4x6 glossy.
# Usage: yazi-print <file>...

set -euo pipefail

if [ $# -eq 0 ]; then
	echo "Usage: yazi-print <file>..." >&2
	exit 1
fi

# ---------- helpers ----------

is_image() {
	case "${1,,}" in
		*.jpg|*.jpeg|*.png|*.webp|*.heic|*.heif|*.tiff|*.tif|*.bmp|*.avif|*.gif) return 0 ;;
		*) return 1 ;;
	esac
}

is_archive() {
	case "${1,,}" in
		*.zip|*.tar.gz|*.tgz|*.tar.bz2|*.tbz2|*.tar.xz|*.txz|*.tar|*.rar|*.7z) return 0 ;;
		*) return 1 ;;
	esac
}

is_pdf() {
	case "${1,,}" in *.pdf) return 0 ;; *) return 1 ;; esac
}

need() {
	command -v "$1" &>/dev/null && return 0
	echo "Missing tool: $1" >&2
	return 1
}

# Pick a printer via fzf (or fall back to numbered choice)
pick_printer() {
	local printers
	mapfile -t printers < <(lpstat -p 2>/dev/null | awk '/^printer / {print $2}')
	if [ ${#printers[@]} -eq 0 ]; then
		echo "No CUPS printers found" >&2
		exit 1
	fi
	if [ ${#printers[@]} -eq 1 ]; then
		echo "${printers[0]}"
		return
	fi
	if command -v fzf &>/dev/null; then
		printf '%s\n' "${printers[@]}" | fzf --prompt="Printer> " --height=40% --reverse
	else
		echo "Available printers:" >&2
		local i=1
		for p in "${printers[@]}"; do
			echo "  $i) $p" >&2
			i=$((i+1))
		done
		printf "Pick [1-%d]: " "${#printers[@]}" >&2
		read -r choice
		echo "${printers[$((choice-1))]}"
	fi
}

# Re-encode every image through magick with explicit density + sRGB.
# Source files often lack density metadata (Facebook/Instagram strip it),
# which makes Canon IPP Everywhere render blank pages. This normalizes.
# Echoes path to print-ready JPEG.
ensure_printable() {
	local src="$1" tmpdir="$2"
	local out
	out="$tmpdir/$(basename "${src%.*}").print.jpg"
	magick "$src" \
		-auto-orient \
		-colorspace sRGB \
		-density 300 -units PixelsPerInch \
		-quality 95 \
		"$out" >&2
	echo "$out"
}

# Pick image print mode once per session.
# Echoes "photo" or "regular".
pick_image_mode() {
	local modes=("photo  — 4x6 borderless glossy (fill)" "regular — A4 plain paper (fit)")
	local choice
	if command -v fzf &>/dev/null; then
		choice="$(printf '%s\n' "${modes[@]}" | fzf --prompt="Image mode> " --height=30% --reverse)"
	else
		echo "Image print mode:" >&2
		local i=1
		for m in "${modes[@]}"; do echo "  $i) $m" >&2; i=$((i+1)); done
		printf "Pick [1-2]: " >&2
		read -r n
		choice="${modes[$((n-1))]}"
	fi
	case "$choice" in
		photo*)   echo "photo" ;;
		regular*) echo "regular" ;;
		*)        echo "photo" ;;  # default if cancelled
	esac
}

# Send one image to printer using selected mode.
print_image() {
	local file="$1" printer="$2" mode="$3"
	echo "→ $(basename "$file") [$mode]" >&2
	if [ "$mode" = "photo" ]; then
		lp -d "$printer" \
			-o media=4x6.Borderless \
			-o MediaType=Com.canon.mtglossy \
			-o print-quality=5 \
			-o print-color-mode=color \
			-o print-scaling=fill \
			"$file" >&2
	else
		lp -d "$printer" \
			-o media=A4 \
			-o print-color-mode=color \
			-o fit-to-page \
			"$file" >&2
	fi
}

# Print a PDF with a chosen page range.
print_pdf() {
	local file="$1" printer="$2"
	echo "PDF: $(basename "$file")" >&2
	if command -v pdfinfo &>/dev/null; then
		local pages
		pages="$(pdfinfo "$file" 2>/dev/null | awk -F': *' '/^Pages:/ {print $2}')"
		[ -n "$pages" ] && echo "  Total pages: $pages" >&2
	fi
	printf "Page range (e.g. 1-3,5 — empty=all): " >&2
	read -r range
	local lp_args=(-d "$printer" -o media=A4 -o sides=one-sided)
	if [ -n "$range" ]; then
		lp_args+=(-P "$range")
	fi
	lp "${lp_args[@]}" "$file" >&2
}

# ---------- main ----------

need magick || exit 1
need lp     || exit 1

printer="$(pick_printer)"
if [ -z "$printer" ]; then
	echo "Cancelled" >&2
	exit 1
fi
echo "Printer: $printer" >&2

# Decide if any input could be an image (so we can prompt for mode upfront).
has_images=0
for arg in "$@"; do
	if is_image "$arg" || is_archive "$arg"; then
		has_images=1; break
	fi
done

img_mode=""
if [ "$has_images" -eq 1 ]; then
	img_mode="$(pick_image_mode)"
	echo "Image mode: $img_mode" >&2
fi
echo >&2

tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT

img_count=0

for arg in "$@"; do
	if is_pdf "$arg"; then
		print_pdf "$arg" "$printer"
	elif is_archive "$arg"; then
		echo "Extracting $(basename "$arg")..." >&2
		extract_dir="$tmpdir/$(basename "$arg").d"
		mkdir -p "$extract_dir"
		case "${arg,,}" in
			*.tar.gz|*.tgz|*.tar.bz2|*.tbz2|*.tar.xz|*.txz|*.tar)
				tar xf "$arg" -C "$extract_dir" ;;
			*)
				nix-shell -p p7zip --run "7z x -o'$extract_dir' -bso0 '$arg'" >&2 ;;
		esac
		while IFS= read -r -d '' f; do
			jpeg="$(ensure_printable "$f" "$tmpdir")"
			print_image "$jpeg" "$printer" "$img_mode"
			img_count=$((img_count+1))
		done < <(find "$extract_dir" -type f \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' -o -iname '*.heic' -o -iname '*.heif' -o -iname '*.tiff' -o -iname '*.tif' -o -iname '*.bmp' -o -iname '*.avif' \) -print0 | sort -z)
	elif is_image "$arg"; then
		jpeg="$(ensure_printable "$arg" "$tmpdir")"
		print_image "$jpeg" "$printer" "$img_mode"
		img_count=$((img_count+1))
	else
		echo "Skipping unsupported: $(basename "$arg")" >&2
	fi
done

if [ "$img_count" -gt 0 ]; then
	echo >&2
	echo "Sent $img_count image(s) to $printer" >&2
	command -v notify-send &>/dev/null && notify-send "yazi-print" "Sent $img_count image(s) to $printer"
fi
