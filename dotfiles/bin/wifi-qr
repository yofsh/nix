#!/bin/sh
# connect to WIFI with the webcam and QR code

QR=$(zbarcam --raw -1)
echo "QR code content:"
echo "$QR"
PREAMBULE=$(echo "$QR" | awk -F'[ ;]' '{print $1}')
QRTYPE=$(echo "$PREAMBULE" | awk -F'[ :]' '{print $1}')
if [ "$QRTYPE" != "WIFI" ]; then
	echo "QR code is not wifi"
	exit 1
fi

get_field() {
	echo "$QR" | sed 's/^WIFI://' | tr ';' '\n' | grep "^$1:" | sed "s/^$1://"
}

TYPE=$(get_field T)
SSID=$(get_field S)
PASSWORD=$(get_field P)
HIDDEN=$(get_field H)

echo "Trying to connect to SSID '$SSID', type $TYPE, hidden: ${HIDDEN:-no}"
nmcli d w l --rescan yes
nmcli dev wifi connect "$SSID" password "$PASSWORD"
