#!/usr/bin/env python3
"""DNS resolution self-test for the quickshell network popup.

Resolves a handful of canonical hostnames via three explicit paths so the
user can see where DNS is (or isn't) working:

  - system:   libc → /etc/resolv.conf → systemd-resolved → upstream.
              Same path apps use. May hit the resolved cache.
  - upstream: raw UDP DNS query to the configured upstream server
              (passed via --upstream). Bypasses libc / resolved cache.
  - external: raw UDP DNS query to 1.1.1.1. Confirms the network can
              reach a public resolver even if local DNS is broken.

Usage:
    qs-dns-test                              # system + external
    qs-dns-test --upstream 192.168.8.30      # all three methods
"""

from __future__ import annotations

import argparse
import concurrent.futures
import json
import random
import socket
import struct
import sys
import time

TARGETS = ["google.com", "cloudflare.com", "github.com"]
EXTERNAL_SERVER = "1.1.1.1"
TIMEOUT = 3.0


def _resolve_via_system(domain: str) -> dict:
    """libc / nsswitch / resolv.conf → systemd-resolved → upstream."""
    start = time.monotonic()
    socket.setdefaulttimeout(TIMEOUT)
    try:
        _, _, ips = socket.gethostbyname_ex(domain)
        elapsed = round((time.monotonic() - start) * 1000)
        return {"domain": domain, "ok": bool(ips), "ip": ips[0] if ips else "",
                "time_ms": elapsed, "error": "" if ips else "no answer"}
    except socket.gaierror as e:
        return {"domain": domain, "ok": False, "ip": "",
                "time_ms": round((time.monotonic() - start) * 1000),
                "error": str(e)}
    except (socket.timeout, OSError) as e:
        return {"domain": domain, "ok": False, "ip": "",
                "time_ms": round((time.monotonic() - start) * 1000),
                "error": str(e) or "timeout"}
    finally:
        socket.setdefaulttimeout(None)


# ── Minimal DNS-over-UDP A-record query (no external deps) ────────────────

def _build_query(domain: str, tid: int) -> bytes:
    # RFC 1035: 12-byte header + question section
    # flags 0x0100 = standard query, recursion desired
    header = struct.pack(">HHHHHH", tid, 0x0100, 1, 0, 0, 0)
    qname = b""
    for label in domain.split("."):
        qname += bytes([len(label)]) + label.encode("ascii")
    qname += b"\x00"
    question = qname + struct.pack(">HH", 1, 1)  # qtype=A, qclass=IN
    return header + question


def _skip_name(data: bytes, pos: int) -> int:
    """Advance past a DNS name (handles compression pointers)."""
    while pos < len(data):
        b = data[pos]
        if b == 0:
            return pos + 1
        if b & 0xC0 == 0xC0:
            return pos + 2
        pos += b + 1
    return pos


def _parse_first_a(data: bytes, expected_tid: int) -> tuple[str, str]:
    if len(data) < 12:
        return "", "short response"
    tid, flags, qdc, anc, _, _ = struct.unpack(">HHHHHH", data[:12])
    if tid != expected_tid:
        return "", "tid mismatch"
    rcode = flags & 0xF
    if rcode != 0:
        return "", "rcode " + str(rcode)
    if anc == 0:
        return "", "no answer"

    pos = 12
    pos = _skip_name(data, pos)  # skip QNAME
    pos += 4                      # skip QTYPE + QCLASS

    for _ in range(anc):
        if pos >= len(data):
            break
        pos = _skip_name(data, pos)
        if pos + 10 > len(data):
            break
        atype, _aclass, _ttl, rdlen = struct.unpack(">HHIH", data[pos:pos + 10])
        pos += 10
        if atype == 1 and rdlen == 4 and pos + 4 <= len(data):
            return ".".join(str(b) for b in data[pos:pos + 4]), ""
        pos += rdlen

    return "", "no A record"


def _resolve_raw(domain: str, server: str) -> dict:
    tid = random.randint(0, 0xFFFF)
    packet = _build_query(domain, tid)

    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    sock.settimeout(TIMEOUT)
    start = time.monotonic()
    try:
        sock.sendto(packet, (server, 53))
        data, _ = sock.recvfrom(4096)
    except socket.timeout:
        return {"domain": domain, "ok": False, "ip": "",
                "time_ms": round(TIMEOUT * 1000), "error": "timeout"}
    except OSError as e:
        return {"domain": domain, "ok": False, "ip": "",
                "time_ms": round((time.monotonic() - start) * 1000),
                "error": str(e)}
    finally:
        sock.close()

    elapsed = round((time.monotonic() - start) * 1000)
    ip, err = _parse_first_a(data, tid)
    return {"domain": domain, "ok": bool(ip), "ip": ip,
            "time_ms": elapsed, "error": err}


def _run_method(method: str, server: str) -> list[dict]:
    if method == "system":
        fn = _resolve_via_system
    else:
        fn = lambda d, srv=server: _resolve_raw(d, srv)
    with concurrent.futures.ThreadPoolExecutor(max_workers=len(TARGETS)) as ex:
        return list(ex.map(fn, TARGETS))


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--upstream", default="",
                        help="upstream DNS server to query directly (e.g. 192.168.8.30)")
    args = parser.parse_args()

    work = [("system", "system")]
    if args.upstream:
        work.append(("upstream", args.upstream))
    work.append(("external", EXTERNAL_SERVER))

    # Run all methods in parallel — each is itself internally parallel across
    # the target list, so the whole panel populates in roughly max(latency).
    methods: dict[str, dict] = {}
    with concurrent.futures.ThreadPoolExecutor(max_workers=len(work)) as ex:
        futures = {name: ex.submit(_run_method, name, srv) for name, srv in work}
        for name, fut in futures.items():
            server = dict(work)[name]
            methods[name] = {"server": server, "tests": fut.result()}

    print(json.dumps({"ts": time.time(), "methods": methods}))


if __name__ == "__main__":
    main()
