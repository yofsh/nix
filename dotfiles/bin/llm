#!/usr/bin/env python3
"""Query LLMs via OpenRouter with streaming, web search, and vision."""

import argparse
import base64
import json
import os
import re
import subprocess
import sys
import signal
import tempfile
import time
import urllib.request
import uuid

API_URL = "https://openrouter.ai/api/v1/chat/completions"
KEY_PATH = "/run/secrets/openrouter-key"
DEFAULT_MODEL = "openai/gpt-5.4"
NOTIFY_INTERVAL = 0.15  # seconds between notification updates
HISTORY_DIR = os.path.expanduser("~/.cache/llm")
HISTORY_FILE = os.path.join(HISTORY_DIR, "history.json")
SESSION_FILE = os.path.join(HISTORY_DIR, "session.json")

TTS_URL = "http://192.168.1.154:8080/v1/audio/speech"
TTS_MODEL = "voice-en-us-libritts-high"


def read_api_key():
    try:
        with open(KEY_PATH) as f:
            return f.read().strip()
    except FileNotFoundError:
        die(f"API key not found at {KEY_PATH}\nAdd 'openrouter-key' to secrets.yaml and rebuild")


def die(msg):
    print(f"llm: {msg}", file=sys.stderr)
    sys.exit(1)


def vlog(msg, verbose):
    """Print a timestamped verbose message to stderr."""
    if verbose:
        print(f"[llm] {msg}", file=sys.stderr)


def log_json(label, obj):
    """Pretty-print JSON via jq to stderr."""
    try:
        proc = subprocess.run(
            ["jq", "."],
            input=json.dumps(obj).encode(),
            capture_output=True,
        )
        formatted = proc.stdout.decode() if proc.returncode == 0 else json.dumps(obj, indent=2)
    except FileNotFoundError:
        formatted = json.dumps(obj, indent=2)
    print(f"\n--- {label} ---\n{formatted}", file=sys.stderr)


def load_history():
    """Load conversation history from cache file."""
    try:
        with open(HISTORY_FILE) as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        return []


def save_history(history):
    """Save conversation history to cache file."""
    os.makedirs(HISTORY_DIR, exist_ok=True)
    with open(HISTORY_FILE, "w") as f:
        json.dump(history, f)


def clear_history():
    """Delete history and session files."""
    for path in (HISTORY_FILE, SESSION_FILE):
        try:
            os.remove(path)
        except FileNotFoundError:
            pass


def save_session(argv):
    """Save CLI args (minus prompt) for follow-up reuse."""
    os.makedirs(HISTORY_DIR, exist_ok=True)
    with open(SESSION_FILE, "w") as f:
        json.dump({"argv": argv}, f)


def capture_screenshot():
    """Capture screen region via grim+slurp, return base64 JPEG."""
    try:
        region = subprocess.run(
            ["slurp"], capture_output=True, text=True, check=True
        ).stdout.strip()
    except (subprocess.CalledProcessError, FileNotFoundError):
        die("slurp cancelled or not found")

    try:
        img = subprocess.run(
            ["grim", "-t", "jpeg", "-q", "80", "-g", region, "-"],
            capture_output=True, check=True,
        ).stdout
    except (subprocess.CalledProcessError, FileNotFoundError):
        die("grim failed or not found")

    return base64.b64encode(img).decode(), "image/jpeg"


def clipboard_image():
    """Get image from clipboard via wl-paste, return base64 PNG."""
    try:
        img = subprocess.run(
            ["wl-paste", "--type", "image/png"],
            capture_output=True, check=True,
        ).stdout
    except (subprocess.CalledProcessError, FileNotFoundError):
        die("no image in clipboard or wl-paste not found")

    if not img:
        die("clipboard is empty")

    return base64.b64encode(img).decode(), "image/png"


TTS_PID_FILE = os.path.join(HISTORY_DIR, "tts.pid")

VOICE_NAME = "llm"
VOICE_TAG_FILE = os.path.join(HISTORY_DIR, "voice.tag")


def voice_is_recording():
    """Check if a voice recording is in progress (via voice script)."""
    try:
        with open(f"/tmp/voice_{VOICE_NAME}.pid") as f:
            os.kill(int(f.read().strip()), 0)
        return True
    except (FileNotFoundError, ValueError, ProcessLookupError):
        return False


def tts_is_playing():
    """Check if TTS playback is in progress."""
    try:
        with open(TTS_PID_FILE) as f:
            pid = int(f.read().strip())
        os.kill(pid, 0)
        return True
    except (FileNotFoundError, ValueError, ProcessLookupError):
        return False


def tts_stop():
    """Stop TTS playback if running."""
    try:
        with open(TTS_PID_FILE) as f:
            pid = int(f.read().strip())
        os.kill(pid, signal.SIGTERM)
    except (FileNotFoundError, ValueError, ProcessLookupError):
        pass
    try:
        os.remove(TTS_PID_FILE)
    except FileNotFoundError:
        pass


def clean_for_tts(text):
    """Strip markdown formatting and emojis for cleaner TTS output."""
    # Code blocks → just the code content
    text = re.sub(r"```\w*\n?", "", text)
    # Inline code
    text = re.sub(r"`([^`]+)`", r"\1", text)
    # Bold/italic
    text = re.sub(r"\*{1,3}(.+?)\*{1,3}", r"\1", text)
    text = re.sub(r"_{1,3}(.+?)_{1,3}", r"\1", text)
    # Strikethrough
    text = re.sub(r"~~(.+?)~~", r"\1", text)
    # Headers
    text = re.sub(r"^#{1,6}\s+", "", text, flags=re.MULTILINE)
    # Links [text](url) → text
    text = re.sub(r"\[([^\]]+)\]\([^)]+\)", r"\1", text)
    # Images ![alt](url) → alt
    text = re.sub(r"!\[([^\]]*)\]\([^)]+\)", r"\1", text)
    # Blockquotes
    text = re.sub(r"^>\s?", "", text, flags=re.MULTILINE)
    # Horizontal rules
    text = re.sub(r"^[-*_]{3,}\s*$", "", text, flags=re.MULTILINE)
    # List markers
    text = re.sub(r"^[\s]*[-*+]\s+", "", text, flags=re.MULTILINE)
    text = re.sub(r"^[\s]*\d+\.\s+", "", text, flags=re.MULTILINE)
    # Emojis (Unicode emoji ranges)
    text = re.sub(
        r"[\U0001F600-\U0001F64F\U0001F300-\U0001F5FF\U0001F680-\U0001F6FF"
        r"\U0001F1E0-\U0001F1FF\U00002702-\U000027B0\U0001FA00-\U0001FA6F"
        r"\U0001FA70-\U0001FAFF\U00002600-\U000026FF\U0000FE00-\U0000FE0F"
        r"\U0000200D\U00002B50\U00002B55\U000023CF\U000023E9-\U000023F3"
        r"\U0001F900-\U0001F9FF]+", "", text)
    # Collapse multiple blank lines
    text = re.sub(r"\n{3,}", "\n\n", text)
    return text.strip()


def tts_speak(text, speed=1.0):
    """Send text to TTS API and play audio via pw-play."""
    body = json.dumps({"model": TTS_MODEL, "input": text, "speed": speed}).encode()
    req = urllib.request.Request(
        TTS_URL,
        data=body,
        headers={"Content-Type": "application/json"},
    )
    try:
        resp = urllib.request.urlopen(req)
    except urllib.error.URLError as e:
        print(f"llm: TTS error: {e}", file=sys.stderr)
        return

    fd, wav_path = tempfile.mkstemp(suffix=".wav")
    os.write(fd, resp.read())
    os.close(fd)

    proc = subprocess.Popen(["pw-play", wav_path])
    with open(TTS_PID_FILE, "w") as f:
        f.write(str(proc.pid))

    proc.wait()

    try:
        os.remove(TTS_PID_FILE)
    except FileNotFoundError:
        pass
    os.unlink(wav_path)


MODEL_PREVIEW_SCRIPT = r'''#!/usr/bin/env python3
import json, os, sys, textwrap

models = json.load(open(os.environ["LLM_MODELS_FILE"]))
mid = sys.argv[1] if len(sys.argv) > 1 else ""
m = next((x for x in models if x["id"] == mid), None)
if not m:
    print("Model not found")
    sys.exit(0)
p = m.get("pricing", {})
ctx = m.get("context_length")
arch = m.get("architecture", {})

print(m.get("name", m["id"]))
print("\u2500" * 40)
if ctx:
    print(f"Context:      {ctx:,}")
print(f"Prompt:       ${p.get('prompt', '?')} /token")
print(f"Completion:   ${p.get('completion', '?')} /token")
if arch.get("modality"):
    print(f"Modality:     {arch['modality']}")
if arch.get("tokenizer"):
    print(f"Tokenizer:    {arch['tokenizer']}")
desc = m.get("description", "")
if desc:
    print()
    print(textwrap.fill(desc, width=55))
'''


def fetch_models():
    """Fetch available models from OpenRouter API."""
    req = urllib.request.Request("https://openrouter.ai/api/v1/models")
    try:
        resp = urllib.request.urlopen(req)
    except urllib.error.HTTPError as e:
        die(f"Failed to fetch models: {e.code}")
    return json.loads(resp.read().decode()).get("data", [])


def pick_model():
    """Interactive model picker using fzf with detail preview."""
    print("Fetching models...", file=sys.stderr)
    models = fetch_models()
    models.sort(key=lambda m: m["id"])

    fd, data_path = tempfile.mkstemp(suffix=".json", prefix="llm-models-")
    with os.fdopen(fd, "w") as f:
        json.dump(models, f)

    fd2, preview_path = tempfile.mkstemp(suffix=".py", prefix="llm-preview-")
    with os.fdopen(fd2, "w") as f:
        f.write(MODEL_PREVIEW_SCRIPT)
    os.chmod(preview_path, 0o755)

    model_ids = "\n".join(m["id"] for m in models)
    try:
        env = os.environ.copy()
        env["LLM_MODELS_FILE"] = data_path
        proc = subprocess.run(
            [
                "fzf",
                "--preview", f"python3 {preview_path} {{}}",
                "--preview-window", "right:50%:wrap",
                "--header", "Pick a model (ESC to cancel)",
            ],
            input=model_ids,
            capture_output=True,
            text=True,
            env=env,
        )
        if proc.returncode != 0:
            return None
        return proc.stdout.strip()
    finally:
        os.unlink(data_path)
        os.unlink(preview_path)


def build_payload(model, prompt, history=None, image=None, system=None, temperature=None):
    """Build the API payload with optional history."""
    msgs = []
    if system:
        msgs.append({"role": "system", "content": system})

    if history:
        msgs.extend(history)

    if image:
        b64, mime = image
        content = [
            {"type": "image_url", "image_url": {"url": f"data:{mime};base64,{b64}"}},
            {"type": "text", "text": prompt},
        ]
    else:
        content = prompt

    msgs.append({"role": "user", "content": content})

    body = {"model": model, "messages": msgs, "stream": True}
    if temperature is not None:
        body["temperature"] = temperature
    return body


class StreamResult:
    """Collects metadata from the SSE stream."""
    def __init__(self):
        self.model = None
        self.cost = None
        self.usage = None

    def title(self, elapsed):
        """Format notification title: model · $cost · time."""
        parts = []
        if self.model:
            # Strip provider prefix (openai/gpt-5.2-chat-xxx -> gpt-5.2-chat-xxx)
            parts.append(self.model.split("/", 1)[-1])
        if self.cost is not None:
            parts.append(f"${self.cost:.4f}")
        parts.append(f"{elapsed:.1f}s")
        return " · ".join(parts)


def stream(api_key, body, verbose=False):
    """Stream SSE response, yield text chunks. Populates result metadata."""
    result = StreamResult()

    req = urllib.request.Request(
        API_URL,
        data=json.dumps(body).encode(),
        headers={
            "Authorization": f"Bearer {api_key}",
            "Content-Type": "application/json",
            "HTTP-Referer": "https://github.com/fobos",
        },
    )

    try:
        resp = urllib.request.urlopen(req)
    except urllib.error.HTTPError as e:
        error_body = e.read().decode()
        try:
            detail = json.loads(error_body).get("error", {}).get("message", error_body)
        except json.JSONDecodeError:
            detail = error_body
        die(f"API error {e.code}: {detail}")

    full_response = []
    for line in resp:
        line = line.decode().strip()
        if not line or line.startswith(":"):
            continue
        if not line.startswith("data: "):
            continue
        payload = line[6:]
        if payload == "[DONE]":
            break
        try:
            chunk = json.loads(payload)
        except json.JSONDecodeError:
            continue
        if verbose:
            full_response.append(chunk)

        # Capture model from first chunk
        if result.model is None and chunk.get("model"):
            result.model = chunk["model"]

        # Capture usage/cost from final chunk
        usage = chunk.get("usage")
        if usage:
            result.usage = usage
            cost_details = usage.get("cost_details", {})
            result.cost = cost_details.get("upstream_inference_cost")

        choices = chunk.get("choices", [])
        if not choices:
            continue
        delta = choices[0].get("delta", {})
        text = delta.get("content")
        if text:
            yield text

    if verbose and full_response:
        log_json("Response (first chunk)", full_response[0])
        if len(full_response) > 1:
            log_json(f"Response (last chunk, {len(full_response)} total)", full_response[-1])

    yield result


def notify(text, tag, title="llm"):
    subprocess.run(
        ["notify-send", "-a", "llm", "-h", f"string:x-tag:{tag}", title, text],
        capture_output=True,
    )


def notify_with_followup(text, title, tag, argv_base):
    """Send final notification with Follow up action, fork to background."""
    pid = os.fork()
    if pid != 0:
        return  # parent continues

    # Child: detach from parent
    os.setsid()

    try:
        action = subprocess.run(
            ["notify-send", "-a", "llm", "-h", f"string:x-tag:{tag}",
             "-A", "followup=Follow up", "--wait", title, text],
            capture_output=True, text=True, timeout=20,
        ).stdout.strip()
    except subprocess.TimeoutExpired:
        action = ""

    if action == "followup":
        r = subprocess.run(
            ["sh", "-c", 'echo "" | vicinae dmenu -p "Follow up?"'],
            capture_output=True, text=True,
        )
        followup = r.stdout.strip() if r.returncode == 0 else ""
        if followup:
            os.execvp("llm", argv_base + [followup])

    os._exit(0)


def main():
    parser = argparse.ArgumentParser(description="Query LLMs via OpenRouter")
    parser.add_argument("prompt", nargs="*", help="prompt text")
    parser.add_argument("-m", "--model", default=DEFAULT_MODEL, help=f"model slug (default: {DEFAULT_MODEL})")
    parser.add_argument("-w", "--web", action="store_true", help="enable web search (:online suffix)")
    parser.add_argument("-i", "--image", action="store_true", help="capture screen region and attach")
    parser.add_argument("-I", "--clipboard-image", action="store_true", help="attach image from clipboard")
    parser.add_argument("-n", "--notify", action="store_true", help="stream to notification instead of stdout")
    parser.add_argument("-s", "--system", help="system message")
    parser.add_argument("-t", "--temperature", type=float, help="temperature (0.0-2.0)")
    parser.add_argument("-c", "--copy", action="store_true", help="copy result to clipboard when done")
    parser.add_argument("-v", "--verbose", action="store_true", help="log request/response JSON to stderr (formatted with jq)")
    parser.add_argument("--raw", action="store_true", help="output raw SSE JSON chunks")
    parser.add_argument("--new", action="store_true", help="clear conversation history and start fresh")
    parser.add_argument("-L", "--list-models", action="store_true", help="pick model interactively with fzf")
    parser.add_argument("-V", "--voice", action="store_true", help="record voice for prompt (STT via Whisper)")
    parser.add_argument("--tts", action="store_true", help="speak response aloud (TTS)")
    parser.add_argument("--tts-speed", type=float, default=1.0, help="TTS playback speed (default: 1.0)")
    args = parser.parse_args()

    # Clear history if requested
    if args.new:
        clear_history()

    # Interactive model picker
    if args.list_models:
        selected = pick_model()
        if not selected:
            sys.exit(0)
        args.model = selected

    # If TTS is playing, stop it and exit
    if tts_is_playing():
        tts_stop()
        sys.exit(0)

    # Unique tag for this invocation so notifications don't clobber each other
    # Voice toggle: reuse the tag from the recording start so it's one continuous notification
    if args.voice and voice_is_recording():
        try:
            with open(VOICE_TAG_FILE) as f:
                tag = f.read().strip()
        except FileNotFoundError:
            tag = f"llm-{uuid.uuid4().hex[:8]}"
    else:
        tag = f"llm-{uuid.uuid4().hex[:8]}"

    # Capture image first so the user can see what they're prompting about
    image = None
    if args.image:
        t = time.monotonic()
        image = capture_screenshot()
        vlog(f"Screenshot captured in {time.monotonic() - t:.2f}s", args.verbose)
    elif args.clipboard_image:
        image = clipboard_image()

    # Gather prompt
    parts = []
    if args.prompt:
        parts.append(" ".join(args.prompt))
    if not sys.stdin.isatty():
        stdin_text = sys.stdin.read().strip()
        if stdin_text:
            parts.append(stdin_text)

    if not parts:
        if args.voice:
            voice_cmd = ["voice", "-m", "dictate", "--name", VOICE_NAME, "-p", "-r"]
            if voice_is_recording():
                # Second press: stop recording, transcribe
                if args.notify:
                    notify("⏳ Transcribing...", tag)
                else:
                    print("Transcribing...", file=sys.stderr)
                t = time.monotonic()
                r = subprocess.run(
                    voice_cmd + ["--stop"],
                    capture_output=True, text=True,
                )
                text = r.stdout.strip()
                vlog(f"STT transcribed in {time.monotonic() - t:.2f}s", args.verbose)
                if not text:
                    if args.notify:
                        notify("No speech detected", tag)
                    else:
                        print("No speech detected", file=sys.stderr)
                    sys.exit(0)
                parts.append(text)
                if args.notify:
                    notify(f"🗣️ {text}", tag)
                else:
                    print(f"Transcribed: {text}", file=sys.stderr)
            else:
                # First press: start recording and exit
                subprocess.run(voice_cmd + ["--start"])
                if args.notify:
                    notify("🎤 Recording... press again to stop", tag)
                else:
                    print("Recording... run again with -V to stop and send", file=sys.stderr)
                os.makedirs(HISTORY_DIR, exist_ok=True)
                with open(VOICE_TAG_FILE, "w") as f:
                    f.write(tag)
                sys.exit(0)
        else:
            # Grab primary selection as context
            sel = ""
            try:
                sel = subprocess.run(
                    ["wl-paste", "-p"], capture_output=True, text=True, timeout=2,
                ).stdout.strip()
            except (subprocess.TimeoutExpired, FileNotFoundError):
                pass
            # Open dmenu for the prompt (Escape = exit)
            try:
                r = subprocess.run(
                    ["sh", "-c", 'echo "" | vicinae dmenu -p "llm?"'],
                    capture_output=True, text=True,
                )
                if r.returncode != 0:
                    sys.exit(0)
                dmenu_prompt = r.stdout.strip()
                if dmenu_prompt:
                    parts.append(dmenu_prompt)
            except FileNotFoundError:
                pass
            # Append selection as context after the prompt
            if sel:
                parts.append(sel)

    if not parts:
        die("no prompt provided (use args, stdin, or select text)")

    prompt = "\n\n".join(parts)

    # Model
    model = args.model
    if args.web and not model.endswith(":online"):
        model += ":online"

    # Load conversation history
    history = load_history()

    api_key = read_api_key()

    # Build payload with history
    body = build_payload(model, prompt, history=history, image=image,
                         system=args.system, temperature=args.temperature)

    if args.verbose:
        # Log request with truncated image data
        log_body = json.loads(json.dumps(body))
        for msg in log_body.get("messages", []):
            if isinstance(msg.get("content"), list):
                for part in msg["content"]:
                    if part.get("type") == "image_url":
                        url = part["image_url"]["url"]
                        part["image_url"]["url"] = url[:60] + "...<truncated>"
        log_json("Request", log_body)

    # Show initial prompt notification before streaming
    if args.notify:
        truncated = prompt[:100] + "..." if len(prompt) > 100 else prompt
        notify(f"⏳ {truncated}", tag, title=model.split("/", 1)[-1])

    if args.raw:
        for item in stream(api_key, body, verbose=args.verbose):
            if isinstance(item, StreamResult):
                break
            print(item, end="", flush=True)
        return

    # Stream
    full_text = []
    last_notify = 0
    t_start = time.monotonic()
    meta = None

    for item in stream(api_key, body, verbose=args.verbose):
        if isinstance(item, StreamResult):
            meta = item
            break
        full_text.append(item)
        if args.notify:
            now = time.monotonic()
            if now - last_notify >= NOTIFY_INTERVAL:
                notify("".join(full_text), tag)
                last_notify = now
        else:
            print(item, end="", flush=True)

    elapsed = time.monotonic() - t_start
    result = "".join(full_text)
    vlog(f"LLM streamed in {elapsed:.2f}s", args.verbose)
    title = meta.title(elapsed) if meta else "llm"

    if not args.notify and result:
        print()  # trailing newline

    if args.copy and result:
        subprocess.run(["wl-copy", result], check=False)

    if not result:
        die("empty response from model")

    # TTS — speak the response (notification keeps showing the result text)
    if args.tts and result:
        if args.notify:
            notify(result, tag, title=f"🔊 {title}")
        t = time.monotonic()
        tts_speak(clean_for_tts(result), speed=args.tts_speed)
        vlog(f"TTS played in {time.monotonic() - t:.2f}s", args.verbose)

    # Save history (text-only, no base64 images)
    history.append({"role": "user", "content": prompt})
    history.append({"role": "assistant", "content": result})
    save_history(history)

    # Build argv base for follow-up reuse (flags only, no prompt)
    argv_base = ["llm"]
    if args.model != DEFAULT_MODEL:
        argv_base += ["-m", args.model]
    if args.web:
        argv_base.append("-w")
    if args.notify:
        argv_base.append("-n")
    if args.system:
        argv_base += ["-s", args.system]
    if args.temperature is not None:
        argv_base += ["-t", str(args.temperature)]
    if args.copy:
        argv_base.append("-c")
    if args.verbose:
        argv_base.append("-v")
    if args.tts:
        argv_base.append("--tts")
    if args.tts_speed != 1.0:
        argv_base += ["--tts-speed", str(args.tts_speed)]
    save_session(argv_base)

    # Final notification: with follow-up button in notify mode, or nothing for stdout
    if args.notify:
        notify_with_followup(result, title, tag, argv_base)


if __name__ == "__main__":
    main()
