#!/usr/bin/env bash
# Search public code on Sourcegraph (sourcegraph.com)
# Usage: sg <query> [--limit N] [--json]
#
# Examples:
#   sg "lang:nix mkOutOfStoreSymlink"
#   sg "lang:go context.WithCancel" --limit 10
#   sg "repo:NixOS/nixpkgs lang:nix mkDerivation pname" --limit 5
#   sg "lang:nix sops.secrets" --json

set -euo pipefail

ENDPOINT="https://sourcegraph.com/.api/search/stream"
LIMIT=20
JSON=false
QUERY=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --limit) LIMIT="$2"; shift 2 ;;
        --json)  JSON=true; shift ;;
        --help|-h)
            sed -n '2,8p' "$0" | sed 's/^# \?//'
            exit 0
            ;;
        *) QUERY="$1"; shift ;;
    esac
done

if [[ -z "$QUERY" ]]; then
    echo "Usage: sg <query> [--limit N] [--json]" >&2
    exit 1
fi

response=$(curl -s --header "Accept:text/event-stream" --get \
    --url "$ENDPOINT" \
    --data-urlencode "q=$QUERY" \
    --data-urlencode "display=$LIMIT" \
    --data-urlencode "t=keyword")

# Extract match data arrays (contain type:"content" entries)
matches=$(echo "$response" | grep '^data: \[' | sed 's/^data: //' \
    | jq -s '[.[][] | select(.type == "content")]' 2>/dev/null)

if [[ -z "$matches" ]] || [[ "$(echo "$matches" | jq 'length')" == "0" ]]; then
    echo "No results found." >&2
    exit 0
fi

if $JSON; then
    echo "$matches"
    exit 0
fi

# Pretty print
echo "$matches" | jq -r '
    .[] |
    "\u001b[1;34m" + .repository + "\u001b[0m " +
    "\u001b[33m" + .path + "\u001b[0m" +
    (if .repoStars and .repoStars > 0 then " \u001b[2m(\(.repoStars)★)\u001b[0m" else "" end) +
    (if .lineMatches then
        "\n" + (.lineMatches[] |
            "  \u001b[2m" + ((.lineNumber + 1) | tostring) + ":\u001b[0m " + .line)
    else "" end) +
    "\n"
'
