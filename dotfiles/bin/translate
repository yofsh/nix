#!/usr/bin/env bash
# translate — translate the selected text via the DeepL API.
#
#   translate <lang> [replace]
#
# Grabs the current selection (simulated copy, clipboard-preserving). With
# `replace`, types the translation over the selection; Spanish replacements get
# accents stripped for plain-ASCII typing.

lang="${1:-}"
mode="${2:-}"

if [[ -z "$lang" ]]; then
  echo "Usage: translate <lang> [replace]" >&2
  exit 1
fi

LIB="$(dirname "$(readlink -f "$0")")/lib"
. "$LIB/clipboard.sh"
. "$LIB/notify.sh"
. "$LIB/secrets.sh"
NTFY_ICON=google-translate
NTFY_TIMEOUT=60000

lang_upper=$(printf '%s' "$lang" | tr '[:lower:]' '[:upper:]')

notify() {
  echo "$1 - ${2:-}"
  ntfy "$1" "${2:-}"
}

translate_deepl() {
  local target_lang="$1" text="$2"
  local payload auth_key response message

  payload=$(jq -n --arg target_lang "$target_lang" --arg text "$text" '{
    target_lang: $target_lang,
    text: [$text]
  }')

  auth_key=$(read_secret deepl-key) || return 1

  response=$(curl -s -X POST \
    -H "Authorization: DeepL-Auth-Key $auth_key" \
    -H "Content-Type: application/json" \
    -d "$payload" \
    "https://api-free.deepl.com/v2/translate")

  message=$(jq -r '.message // empty' <<< "$response")
  if [[ "$message" == "Quota exceeded" ]]; then
    echo "Error: DeepL API quota exceeded."
    return 1
  elif ! jq -e '.translations[0].text' >/dev/null 2>&1 <<< "$response"; then
    echo "Response"
    jq <<< "$response"
    echo "Error: Invalid response or translation failed."
    return 1
  fi

  jq -r '.translations[0].text' <<< "$response"
}

strip_accents() {
  echo "$1" | sed 's/á/a/g; s/é/e/g; s/í/i/g; s/ó/o/g; s/ú/u/g; s/ü/u/g; s/ñ/n/g; s/Á/A/g; s/É/E/g; s/Í/I/g; s/Ó/O/g; s/Ú/U/g; s/Ü/U/g; s/¿//g;'
}

original=$(get_selection)

if [[ "$mode" == "replace" ]]; then
  notify "Getting $lang_upper replacement for:" "$original"
  translation=$(translate_deepl "$lang" "$original")
  replace_selection "$(strip_accents "$translation")" "$original"
  notify "Done!"
  exit 0
fi

notify "Getting $lang_upper translation for:" "$original"
translation=$(translate_deepl "$lang" "$original")
notify " " "$translation"
