#!/usr/bin/env bash
# Toggle dark/light mode via dconf (read by xdg-desktop-portal-gtk)

set -euo pipefail

current=$(dconf read /org/gnome/desktop/interface/color-scheme 2>/dev/null) || true

if [[ "$current" == "'prefer-dark'" ]]; then
  target_scheme="'prefer-light'"
  target_gtk="adw-gtk3"
else
  target_scheme="'prefer-dark'"
  target_gtk="adw-gtk3-dark"
fi

dconf write /org/gnome/desktop/interface/color-scheme "$target_scheme"
dconf write /org/gnome/desktop/interface/gtk-theme "'$target_gtk'"
