#!/usr/bin/env bash
# ha - Control Home Assistant entities
# Usage: ha <action> <entity_id>
#   actions: toggle, up, down, open, close, scene

HA_URL="http://192.168.8.30:8123"
HA_TOKEN=$(< /run/secrets/ha-token)
STEP=12  # brightness step (0-255 scale, ~10%)
ICON="go-home"

ACTION="${1:-}"
ENTITY="${2:-}"
DOMAIN=${ENTITY%%.*}

if [[ -z "$ACTION" || -z "$ENTITY" ]]; then
  echo "Usage: ha <toggle|up|down|scene> <entity_id>" >&2
  exit 1
fi

api() { curl -s -H "Authorization: Bearer $HA_TOKEN" -H "Content-Type: application/json" "$@"; }

notify() { notify-send -h "string:x-tag:ha" -t 2000 -u low -i "$ICON" "$@"; }

case $ACTION in
  up|down)
    state=$(api "$HA_URL/api/states/$ENTITY")
    current=$(echo "$state" | jq -r '(.attributes.brightness // 0) | floor')
    name=$(echo "$state" | jq -r --arg entity "$ENTITY" '.attributes.friendly_name // $entity')

    if [ "$ACTION" = "up" ]; then
      new=$((current + STEP))
      [ $new -gt 255 ] && new=255
    else
      new=$((current - STEP))
      [ $new -lt 0 ] && new=0
    fi

    if [ $new -eq 0 ]; then
      api -X POST -d "{\"entity_id\":\"$ENTITY\"}" "$HA_URL/api/services/light/turn_off" >/dev/null
      notify -h "int:value:0" "$name" "OFF"
    else
      resp=$(api -X POST -d "{\"entity_id\":\"$ENTITY\",\"brightness\":$new}" "$HA_URL/api/services/light/turn_on")
      applied=$(echo "$resp" | jq -r --arg entity "$ENTITY" '[.[] | select(.entity_id == $entity)] | .[0].attributes.brightness // empty')
      [ -z "$applied" ] && applied=$new
      pct=$((applied * 100 / 255))
      notify -h "int:value:$pct" "$name" "$pct%"
    fi
    ;;

  toggle)
    state=$(api "$HA_URL/api/states/$ENTITY")
    name=$(echo "$state" | jq -r --arg entity "$ENTITY" '.attributes.friendly_name // $entity')

    resp=$(api -X POST -d "{\"entity_id\":\"$ENTITY\"}" "$HA_URL/api/services/$DOMAIN/toggle")
    new_state=$(echo "$resp" | jq -r --arg entity "$ENTITY" '[.[] | select(.entity_id == $entity)] | .[0].state // empty')
    new_brightness=$(echo "$resp" | jq -r --arg entity "$ENTITY" '[.[] | select(.entity_id == $entity)] | .[0].attributes.brightness // 0')

    if [ "$new_state" = "on" ]; then
      pct=$((new_brightness * 100 / 255))
      [ $pct -eq 0 ] && pct=100
      notify -h "int:value:$pct" "$name" "ON · $pct%"
    else
      notify -h "int:value:0" "$name" "OFF"
    fi
    ;;

  next_preset)
    # Cycle to next option on a select entity (e.g. WLED preset)
    state=$(api "$HA_URL/api/states/$ENTITY")
    name=$(echo "$state" | jq -r --arg entity "$ENTITY" '.attributes.friendly_name // $entity')
    current=$(echo "$state" | jq -r '.state')
    options=$(echo "$state" | jq -r '.attributes.options // []')
    count=$(echo "$options" | jq 'length')

    if [ "$count" -eq 0 ]; then
      notify "$name" "No presets"
    else
      idx=$(echo "$options" | jq -r --arg c "$current" 'to_entries | map(select(.value == $c)) | .[0].key // -1')
      next_idx=$(( (idx + 1) % count ))
      next_val=$(echo "$options" | jq -r ".[$next_idx]")
      api -X POST -d "{\"entity_id\":\"$ENTITY\",\"option\":\"$next_val\"}" "$HA_URL/api/services/select/select_option" >/dev/null &
      notify "$name" "$next_val"
    fi
    ;;

  open|close)
    state=$(api "$HA_URL/api/states/$ENTITY")
    name=$(echo "$state" | jq -r --arg entity "$ENTITY" '.attributes.friendly_name // $entity')
    api -X POST -d "{\"entity_id\":\"$ENTITY\"}" "$HA_URL/api/services/cover/${ACTION}_cover" >/dev/null &
    if [ "$ACTION" = "open" ]; then
      notify "$name" "OPENING ▲"
    else
      notify "$name" "CLOSING ▼"
    fi
    ;;

  scene)
    api -X POST -d "{\"entity_id\":\"$ENTITY\"}" "$HA_URL/api/services/scene/turn_on" >/dev/null &
    scene_name=$(echo "$ENTITY" | sed 's/scene\.//' | tr '_' ' ')
    notify "$scene_name"
    ;;
esac
