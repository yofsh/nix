#!/usr/bin/env bash

usage() {
	cat <<EOF
   Usage: $0 [params]

   Region:
    -f, --fullscreen
    -w, --window
    -r, --region

   Action:
    -s, --save
    -c, --copy
    -e, --edit

    -n, --notify            Enabled notification
    -l, --location <DIR>    Directory to save screenshots, defaults to $(xdg-user-dir PICTURES)/screenshots
    -u, --upload            Upload file to remote server
EOF
	exit 1
}

notify() {
	if [[ "$NOTIFY" == true ]]; then
		notify-send -u low -i background "Screenshot $TYPE $ACTION" "$1"
	fi
}

warm_satty_cache() {
	local satty_bin
	local deps=()
	local dep
	satty_bin=$(command -v satty) || return 0
	while IFS= read -r dep; do
		deps+=("$dep")
	done < <(ldd "$satty_bin" 2>/dev/null | awk '/=>/{print $3}')
	cat "$satty_bin" "${deps[@]}" > /dev/null 2>&1 &
}

if ! VALID_ARGS=$(getopt -o ufwrascenl:h --long upload,fullscreen,window,region,save,copy,edit,notify,location:,help -- "$@"); then
	exit 1
fi

TYPE=full
ACTION=copy
NOTIFY=false
UPLOAD=false
FN=$(date "+%Y.%m.%d-%H:%M:%S")
EXT="jpeg"
LOCATION=$(xdg-user-dir PICTURES)/screenshots
FILE=$LOCATION/screenshot-$FN.$EXT
TMPBASE=/tmp/src-$FN
TMPFILE=$TMPBASE.$EXT
PNGFILE=$TMPBASE.png

eval set -- "$VALID_ARGS"
while true; do
	case "$1" in
	-h | --help)
		usage
		;;
	-l | --location)
		LOCATION=$2
		shift 2
		;;
	-r | --region)
		TYPE=region
		shift
		;;
	-u | --upload)
		UPLOAD=true
		shift
		;;
	-n | --notify)
		NOTIFY=true
		shift
		;;
	-f | --fullscreen)
		TYPE=full
		shift
		;;
	-w | --window)
		TYPE=window
		shift
		;;
	-s | --save)
		ACTION=save
		shift
		;;
	-c | --copy)
		ACTION=copy
		shift
		;;
	-e | --edit)
		ACTION=edit
		shift
		;;
	--)
		shift
		break
		;;
	esac
done

mkdir -p "$LOCATION"

case "$TYPE" in
region)
		warm_satty_cache
		GEOMETRY=$(slurp 2>&1)
		;;
	full)
		warm_satty_cache
		GEOMETRY=""
		;;
	window)
		warm_satty_cache
		if pgrep -x "Hyprland" >/dev/null; then
			GEOMETRY=$(hyprctl activewindow -j | jq -r '"\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"')
		elif pgrep -x "sway" >/dev/null; then
			GEOMETRY=$(swaymsg -t get_tree | jq -r '.. | select(.pid? and .visible?) | .rect | "\(.x),\(.y) \(.width)x\(.height)"' | slurp)
		else
			GEOMETRY=""
		fi
		;;
	*)
		echo "Please specify action"
		usage
		;;
esac

if [[ "$GEOMETRY" == "selection cancelled" ]]; then
	echo "Region selection was cancelled, aborting"
	exit 2
fi

if [[ -z "$GEOMETRY" ]]; then
	grim -t "$EXT" "$TMPFILE"
else
	grim -t "$EXT" -g "$GEOMETRY" "$TMPFILE"
fi

ensure_png() {
	convert "$TMPFILE" "$PNGFILE"
}

case "$ACTION" in
	save)
		cp "$TMPFILE" "$FILE"
		ensure_png
		wl-copy < "$PNGFILE"
		notify "Saved to \n\n$FILE\n\n and copied to clipboard"
		;;
	edit)
		rm -f "$PNGFILE"
		GSK_RENDERER=ngl satty --filename "$TMPFILE" --output-filename "$PNGFILE" --init-tool brush --copy-command wl-copy --early-exit
		if [[ -e "$PNGFILE" ]]; then
			convert "$PNGFILE" "$TMPFILE"
			cp "$TMPFILE" "$FILE"
			notify "Image saved!"
		else
			echo "File does not exist"
		fi
		;;
	copy)
		ensure_png
		wl-copy < "$PNGFILE"
		notify "Copied to clipboard!"
		;;
	*)
		ensure_png
		wl-copy < "$PNGFILE"
		notify "Copied to clipboard!"
		;;
esac

if [[ "$UPLOAD" == true ]]; then
	notify "Uploading file to remote server..."
	scp "$TMPFILE" "yof.sh:httpdocs/src/$FN.$EXT"
	notify "File uploaded! URL copied"
	echo "https://yof.sh/src/$FN.$EXT"
	wl-copy "https://yof.sh/src/$FN.$EXT"
fi

rm -f "$TMPFILE" "$PNGFILE"
