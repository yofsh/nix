#!/usr/bin/env bash

usage() {
	cat <<EOF
   Usage: $0 [params]

   Region:
    -f, --fullscreen
    -w, --window
    -r, --region

   Action:
    -s, --save
    -c, --copy
    -e, --edit

    -n, --notify            Enabled notification
    -l, --location <DIR>    Directory to save screenshots, defaults to $(xdg-user-dir PICTURES)/screenshots
    -u, --upload            Upload file to remote server
EOF
	exit 1
}

notify() {
	if [[ "$NOTIFY" == true ]]; then
		notify-send -u low -i applets-screenshooter "Screenshot $TYPE $ACTION" "$1"
	fi
}

warm_satty_cache() {
	local satty_bin
	local deps=()
	local dep
	satty_bin=$(command -v satty) || return 0
	while IFS= read -r dep; do
		deps+=("$dep")
	done < <(ldd "$satty_bin" 2>/dev/null | awk '/=>/{print $3}')
	cat "$satty_bin" "${deps[@]}" > /dev/null 2>&1 &
}

# edit_in_satty TMPFILE PNGFILE OUTFILE — annotate the captured buffer in satty,
# write the result back over OUTFILE and copy it to the clipboard. Returns 1
# when satty was closed without saving.
edit_in_satty() {
	local tmpfile="$1" pngfile="$2" outfile="$3"
	rm -f "$pngfile"
	GSK_RENDERER=ngl satty --filename "$tmpfile" --output-filename "$pngfile" --init-tool brush --copy-command wl-copy --early-exit
	[[ -e "$pngfile" ]] || return 1
	magick "$pngfile" "$tmpfile"
	cp "$tmpfile" "$outfile"
}

# Re-entry used by the "Open in editor" notification action: same editor flow as
# --edit. Invoked detached so the original run can exit while the notification
# waits for a click; owns the temp files either way.
if [[ "$1" == "--edit-buffer" ]]; then
	if edit_in_satty "$2" "$3" "$4"; then
		notify-send -u low -i applets-screenshooter "Screenshot edited" "Annotated copy saved and copied to clipboard"
	fi
	rm -f "$2" "$3"
	exit 0
fi

if ! VALID_ARGS=$(getopt -o ufwrascenl:h --long upload,fullscreen,window,region,save,copy,edit,notify,location:,help -- "$@"); then
	exit 1
fi

TYPE=full
ACTION=copy
NOTIFY=false
UPLOAD=false
FN=$(date "+%Y.%m.%d-%H:%M:%S")
EXT="jpeg"
LOCATION=$(xdg-user-dir PICTURES)/screenshots
FILE=$LOCATION/screenshot-$FN.$EXT
TMPBASE=/tmp/src-$FN
TMPFILE=$TMPBASE.$EXT
PNGFILE=$TMPBASE.png

eval set -- "$VALID_ARGS"
while true; do
	case "$1" in
	-h | --help)
		usage
		;;
	-l | --location)
		LOCATION=$2
		shift 2
		;;
	-r | --region)
		TYPE=region
		shift
		;;
	-u | --upload)
		UPLOAD=true
		shift
		;;
	-n | --notify)
		NOTIFY=true
		shift
		;;
	-f | --fullscreen)
		TYPE=full
		shift
		;;
	-w | --window)
		TYPE=window
		shift
		;;
	-s | --save)
		ACTION=save
		shift
		;;
	-c | --copy)
		ACTION=copy
		shift
		;;
	-e | --edit)
		ACTION=edit
		shift
		;;
	--)
		shift
		break
		;;
	esac
done

mkdir -p "$LOCATION"

case "$TYPE" in
region)
		warm_satty_cache
		# Freeze the screen so menus/tooltips/animations don't vanish during selection.
		# hyprpicker -z paints a frozen snapshot overlay that slurp + grim then capture.
		if command -v hyprpicker >/dev/null && [[ -n "$HYPRLAND_INSTANCE_SIGNATURE" ]]; then
			hyprpicker -r -z >/dev/null 2>&1 &
			HYPRPICKER_PID=$!
			trap '[[ -n "$HYPRPICKER_PID" ]] && kill "$HYPRPICKER_PID" 2>/dev/null' EXIT
			sleep 0.2
		fi
		GEOMETRY=$(slurp 2>&1)
		;;
	full)
		warm_satty_cache
		GEOMETRY=""
		;;
	window)
		warm_satty_cache
		if [[ -n "$HYPRLAND_INSTANCE_SIGNATURE" ]]; then
			GEOMETRY=$(hyprctl activewindow -j | jq -r '"\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"')
		elif pgrep -x "sway" >/dev/null; then
			GEOMETRY=$(swaymsg -t get_tree | jq -r '.. | select(.pid? and .visible?) | .rect | "\(.x),\(.y) \(.width)x\(.height)"' | slurp)
		else
			GEOMETRY=""
		fi
		;;
	*)
		echo "Please specify action"
		usage
		;;
esac

if [[ "$GEOMETRY" == "selection cancelled" ]]; then
	echo "Region selection was cancelled, aborting"
	exit 2
fi

if [[ -z "$GEOMETRY" ]]; then
	grim -t "$EXT" "$TMPFILE"
else
	grim -t "$EXT" -g "$GEOMETRY" "$TMPFILE"
fi

# Release the frozen overlay now that the capture is done (before satty opens).
if [[ -n "$HYPRPICKER_PID" ]]; then
	kill "$HYPRPICKER_PID" 2>/dev/null
	HYPRPICKER_PID=""
fi

ensure_png() {
	magick "$TMPFILE" "$PNGFILE"
}

OFFER_EDITOR=false
NOTIFY_BODY=""

case "$ACTION" in
	save)
		cp "$TMPFILE" "$FILE"
		ensure_png
		wl-copy < "$PNGFILE"
		NOTIFY_BODY="Saved to \n\n$FILE\n\n and copied to clipboard"
		OFFER_EDITOR=true
		;;
	edit)
		if edit_in_satty "$TMPFILE" "$PNGFILE" "$FILE"; then
			notify "Image saved!"
		else
			echo "File does not exist"
		fi
		;;
	copy|*)
		ensure_png
		wl-copy < "$PNGFILE"
		NOTIFY_BODY="Copied to clipboard!"
		OFFER_EDITOR=true
		;;
esac

if [[ "$UPLOAD" == true ]]; then
	notify "Uploading to share.yof.sh..."
	if URL=$(upload put "$TMPFILE" "screenshot-$FN.$EXT"); then
		echo "$URL"
		wl-copy "$URL"
		notify "Uploaded — URL copied: $URL"
	else
		notify "Upload failed"
	fi
fi

if [[ "$OFFER_EDITOR" == true && "$NOTIFY" == true ]]; then
	# Notify with actions: open in satty, or run the captured image through llm
	# (describe / Google Lens). notify-send blocks until an action is clicked or
	# the notification expires, so run it detached: the handler keeps the buffer
	# alive, dispatches the chosen action, and owns temp-file cleanup either way.
	# describe/lens re-copy the PNG to the clipboard first so `llm -I` picks up
	# this screenshot even if the clipboard has since changed.
	SELF=$(realpath "$0")
	setsid -f bash -c '
		body=$1 title=$2 self=$3 tmpfile=$4 pngfile=$5 outfile=$6
		action=$(notify-send -u low -i applets-screenshooter \
			-A "edit=Open in editor" \
			-A "upload=Upload" \
			-A "describe=Describe" \
			-A "lens=Lens" \
			"$title" "$body")
		case "$action" in
			edit)
				"$self" --edit-buffer "$tmpfile" "$pngfile" "$outfile"
				;;
			upload)
				if url=$(upload put "$tmpfile" "$(basename "$outfile")"); then
					upload uploaded "Screenshot uploaded" "$url"
				else
					notify-send -u low -i dialog-error "Upload failed" "share.yof.sh"
				fi
				rm -f "$tmpfile" "$pngfile"
				;;
			describe)
				wl-copy < "$pngfile"
				llm -I -n "Describe this image."
				rm -f "$tmpfile" "$pngfile"
				;;
			lens)
				wl-copy < "$pngfile"
				llm -I --lens
				rm -f "$tmpfile" "$pngfile"
				;;
			*)
				rm -f "$tmpfile" "$pngfile"
				;;
		esac
	' _ "$NOTIFY_BODY" "Screenshot $TYPE $ACTION" "$SELF" "$TMPFILE" "$PNGFILE" "$FILE"
else
	[[ -n "$NOTIFY_BODY" ]] && notify "$NOTIFY_BODY"
	rm -f "$TMPFILE" "$PNGFILE"
fi
