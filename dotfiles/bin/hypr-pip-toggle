#!/usr/bin/env bash
# Toggle PiP-like mode on active window: pin, float, no_focus, resize to corner
# Second press restores the window to its previous state

read -r ADDR PINNED FLOATING MONITOR < <(hyprctl activewindow -j \
    | jq -r '"\(.address) \(.pinned) \(.floating) \(.monitor)"')

ld() { hyprctl dispatch "$1" >/dev/null; }

if [ "$PINNED" = "true" ]; then
    # Restore
    ld "hl.dsp.window.pin()"
    ld "hl.dsp.window.set_prop({ prop = \"no_focus\", value = 0, window = \"address:$ADDR\" })"
    ld "hl.dsp.window.set_prop({ prop = \"opacity\", value = 1.0, window = \"address:$ADDR\" })"
    [ "$FLOATING" = "true" ] && ld 'hl.dsp.window.float({ action = "toggle" })'
    notify-send -t 1500 "PiP off"
else
    # Logical (scaled) dimensions of the window's monitor, for corner positioning
    read -r MON_W MON_H < <(hyprctl monitors -j \
        | jq -r --argjson id "$MONITOR" '.[] | select(.id == $id) | "\(.width / .scale | floor) \(.height / .scale | floor)"')
    PIP_W=800
    PIP_H=450
    POS_X=$((MON_W - PIP_W - 20))
    POS_Y=20

    [ "$FLOATING" = "false" ] && ld 'hl.dsp.window.float({ action = "toggle" })'
    ld "hl.dsp.window.pin()"
    ld "hl.dsp.window.resize({ x = $PIP_W, y = $PIP_H, relative = false })"
    ld "hl.dsp.window.move({ x = $POS_X, y = $POS_Y, relative = false, window = \"address:$ADDR\" })"
    ld "hl.dsp.window.set_prop({ prop = \"no_focus\", value = 1, window = \"address:$ADDR\" })"
    ld "hl.dsp.window.set_prop({ prop = \"opacity\", value = 0.85, window = \"address:$ADDR\" })"
    notify-send -t 1500 "PiP on (pinned, no focus)"
fi
