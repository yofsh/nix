#!/usr/bin/env bash
# ocr — select a screen region, OCR it (eng+ukr+rus+spa), copy the text.
set -uo pipefail

LIB="$(dirname "$(readlink -f "$0")")/lib"
. "$LIB/capture.sh"
. "$LIB/notify.sh"
NTFY_ICON=clipboard

img=$(mktemp --suffix=.jpg)
trap 'rm -f "$img"' EXIT

grab_region "$img" 60 || exit 1   # selection cancelled

# Upscale before tesseract — small UI text OCRs far better at 300dpi-ish sizes.
text=$(magick "$img" -density 300 -resize 300% png:- \
	| tesseract - - --oem 1 -l eng+ukr+rus+spa --dpi 300)

if [ -n "$text" ]; then
	echo "$text"
	wl-copy "$text"
	ntfy "Text copied to clipboard" "$text"
else
	ntfy "No text found in selection"
	exit 1
fi
