#!/usr/bin/env python3
"""Read keybindings from `hyprctl binds -j` and emit structured JSON.

Replaces the old hyprland.conf parser. Now that hyprland.lua sets
`{ description = "..." }` on most binds, `hyprctl binds -j` returns the
description natively; this script just groups by submap and adds a
pretty-printed label used by the quickshell submap overlay.
"""

import argparse
import json
import os
import subprocess
import sys

MOD_ORDER = {"SUPER": 0, "CTRL": 1, "ALT": 2, "SHIFT": 3}

# Standard xkb modifier mask bits.
MOD_BITS = [
    (64, "SUPER"),
    (8,  "ALT"),
    (4,  "CTRL"),
    (1,  "SHIFT"),
]

COMMAND_NAMES = {
    "firefox": "Firefox",
    "google-chrome-stable": "Google Chrome",
    "obsidian": "Obsidian",
    "pactl": "PulseAudio control",
    "wpctl": "WirePlumber control",
    "playerctl": "Media player control",
    "light": "Screen brightness",
    "hyprlock": "Lock screen",
    "wofi": "App launcher (wofi)",
    "vicinae": "App launcher (vicinae)",
    "htop": "System monitor (htop)",
    "btop": "System monitor (btop)",
    "glances": "System monitor (glances)",
    "systemctl": "Systemd control",
    "shutdown": "Shutdown",
    "reboot": "Reboot",
    "xdg-open": "Open URL",
    "wl-paste": "Clipboard paste",
    "foot": "Terminal (foot)",
    "nvim": "Neovim",
    "gping": "Graphical ping",
    "nmcli": "Network manager",
    "curl": "Fetch URL",
    "journalctl": "System journal",
    "killall": "Kill process",
    "powerprofilesctl": "Power profile control",
}

XF86_NAMES = {
    "XF86AudioRaiseVolume": "Volume Up",
    "XF86AudioLowerVolume": "Volume Down",
    "XF86AudioMute": "Mute Audio",
    "XF86AudioMicMute": "Mute Microphone",
    "XF86MonBrightnessUp": "Brightness Up",
    "XF86MonBrightnessDown": "Brightness Down",
    "XF86AudioPlay": "Media Play",
    "XF86AudioPause": "Media Pause",
    "XF86AudioNext": "Media Next",
    "XF86AudioPrev": "Media Previous",
}

DIRECTIONS = {"l": "left", "r": "right", "u": "up", "d": "down"}

LAYOUT_MSGS = {
    "rollnext": "Roll next",
    "rollprev": "Roll previous",
    "swapnext": "Swap with next",
    "swapprev": "Swap with previous",
    "togglesplit": "Toggle split",
    "swapsplit": "Swap split",
    "orientationbottom": "Orientation bottom",
    "orientationtop": "Orientation top",
    "orientationleft": "Orientation left",
    "orientationright": "Orientation right",
    "orientationcenter": "Orientation center",
    "orientationnext": "Orientation next",
    "orientationprev": "Orientation previous",
    "promote": "Promote to master",
}

KEY_NAMES = {
    "RETURN": "Enter",
    "escape": "Esc",
    "grave": "`",
    "minus": "-",
    "plus": "+",
    "equal": "=",
    "bracketleft": "[",
    "bracketright": "]",
    "backslash": "\\",
    "period": ".",
    "comma": ",",
    "TAB": "Tab",
    "mouse:272": "LMB",
    "mouse:273": "RMB",
    "mouse_down": "Scroll Down",
    "mouse_up": "Scroll Up",
    "left": "←",
    "right": "→",
    "up": "↑",
    "down": "↓",
    **XF86_NAMES,
}

MOD_ICONS = {
    "SUPER": "\U000f0633",   # 󰘳 nf-md-apple_keyboard_command
    "CTRL":  "\U000f0634",   # 󰘴 nf-md-apple_keyboard_control
    "ALT":   "\U000f0635",   # 󰘵 nf-md-apple_keyboard_option
    "SHIFT": "\U000f0636",   # 󰘶 nf-md-apple_keyboard_shift
}


def modmask_to_mods(modmask):
    """Decode an xkb modmask int into a canonical 'SUPER CTRL ALT SHIFT' string."""
    parts = [name for bit, name in MOD_BITS if modmask & bit]
    parts.sort(key=lambda m: MOD_ORDER.get(m, 99))
    return " ".join(parts)


def format_pretty(mods, key, description):
    display_key = KEY_NAMES.get(key, key.upper() if len(key) == 1 else key)
    parts = [MOD_ICONS.get(m, m) for m in mods.split()] if mods else []
    parts.append(display_key)
    combo = " ".join(parts)
    return f"{combo} — {description}"


def describe_exec(args):
    cmd = args.strip()
    if not cmd:
        return "Execute command"
    # Strip inline rules like [float; size ...]
    import re
    cmd = re.sub(r'^\[.*?\]\s*', '', cmd)
    # Strip env var prefixes
    while re.match(r'^[A-Z_]+=', cmd):
        cmd = re.sub(r'^[A-Z_]+="[^"]*"\s*', '', cmd)
        cmd = re.sub(r"^[A-Z_]+='[^']*'\s*", '', cmd)
        cmd = re.sub(r'^[A-Z_]+=\S+\s+', '', cmd)
    if not cmd:
        return "Execute command"
    base = os.path.basename(cmd.split()[0])
    rest = cmd[len(cmd.split()[0]):].strip()
    if base in COMMAND_NAMES:
        return f"{COMMAND_NAMES[base]}: {rest}" if rest else COMMAND_NAMES[base]
    if base.endswith(".sh"):
        return f"Run {base[:-3]}: {rest}" if rest else f"Run {base[:-3]}"
    return f"Run {base}: {rest}" if rest else f"Run {base}"


def auto_describe(dispatcher, args):
    """Fallback when hyprctl returns no description."""
    d = (dispatcher or "").strip().lower()
    a = (args or "").strip()

    if d == "exec":
        return describe_exec(a)
    if d == "workspace":
        if a.startswith("e+") or a.startswith("e-"):
            return f"Switch to workspace (relative): {a}"
        return f"Switch to workspace {a}"
    if d == "movetoworkspace":
        return "Move window to special workspace" if a == "special" else f"Move window to workspace {a}"
    if d == "movetoworkspacesilent":
        return "Move window silently to special workspace" if a == "special" else f"Move window silently to workspace {a}"
    if d == "togglespecialworkspace":
        return f"Toggle special workspace: {a}" if a else "Toggle special workspace"
    if d == "movefocus":
        return f"Focus {DIRECTIONS.get(a, a)}"
    if d == "movewindow":
        return "Move window (mouse)" if not a else f"Move window {DIRECTIONS.get(a, a)}"
    if d == "resizewindow":
        return "Resize window (mouse)"
    if d == "resizeactive":
        return f"Resize active window: {a}"
    if d == "killactive":
        return "Kill active window"
    if d == "togglefloating":
        return "Toggle floating"
    if d == "fullscreen":
        return "Toggle fullscreen"
    if d == "pseudo":
        return "Toggle pseudo-tiling"
    if d == "pin":
        return "Pin window"
    if d == "cyclenext":
        return "Cycle to previous window" if a == "prev" else "Cycle to next window"
    if d == "exit":
        return "Exit Hyprland"
    if d == "layoutmsg":
        return f"Layout: {LAYOUT_MSGS.get(a, a)}"
    if d == "submap":
        return f"Enter submap: {a}"
    if ":" in d:
        plugin, action = d.split(":", 1)
        return f"{plugin}: {action} {a}".rstrip() if a else f"{plugin}: {action}"
    return f"{d} {a}".strip() or d


def fetch_binds():
    """Run `hyprctl binds -j` and return the parsed list."""
    try:
        result = subprocess.run(
            ["hyprctl", "binds", "-j"],
            check=True, capture_output=True, text=True,
        )
    except FileNotFoundError:
        print("Error: hyprctl not found on PATH", file=sys.stderr)
        sys.exit(1)
    except subprocess.CalledProcessError as e:
        print(f"Error: hyprctl binds -j failed: {e.stderr}", file=sys.stderr)
        sys.exit(1)
    return json.loads(result.stdout)


def build(binds):
    """Group hyprctl binds output into the JSON shape BarHost.qml expects."""
    global_binds = []
    submaps = {}              # name -> {"binds": [...], "label": str, "activator": {...}}
    submap_activators = {}    # name -> {"mods": str, "key": str}

    for b in binds:
        dispatcher = b.get("dispatcher", "") or ""
        args = b.get("arg", "") or ""
        submap = (b.get("submap") or "").strip()
        mods = modmask_to_mods(b.get("modmask", 0))
        key = b.get("key", "") or ""

        # Skip reset-only stubs (submap → reset has no user-facing label).
        if dispatcher == "submap" and args == "reset":
            continue

        # Submap activator binds defined at the global level.
        if dispatcher == "submap" and not submap and args:
            submap_activators[args] = {"mods": mods, "key": key}
            # Don't display the activator inside the submap list; still show it globally below.

        description = b.get("description") or ""
        if not description:
            description = auto_describe(dispatcher, args)

        # Determine bind-type flag string (matches old contract: bind / binde / bindl / bindm / etc.)
        flags = ""
        if b.get("locked"):     flags += "l"
        if b.get("release"):    flags += "r"
        if b.get("repeat"):     flags += "e"
        if b.get("mouse"):      flags += "m"
        if b.get("non_consuming"): flags += "n"
        if b.get("longPress"):  flags += "p"
        bind_type = "bind" + flags

        entry = {
            "mods": mods,
            "key": key,
            "dispatcher": dispatcher,
            "args": args,
            "description": description,
            "pretty": format_pretty(mods, key, description),
            "type": bind_type,
        }

        if submap:
            sm = submaps.setdefault(submap, {"binds": [], "label": submap, "activator": None})
            sm["binds"].append(entry)
        else:
            global_binds.append(entry)

    # Attach activators to each submap entry.
    for name, sm in submaps.items():
        if name in submap_activators:
            sm["activator"] = submap_activators[name]

    submaps_list = []
    for name, sm in submaps.items():
        entry = {"name": name, "label": sm["label"]}
        if sm["activator"]:
            entry["activator"] = sm["activator"]
        entry["binds"] = sm["binds"]
        submaps_list.append(entry)

    return {"global": global_binds, "submaps": submaps_list}


def main():
    parser = argparse.ArgumentParser(description="Read Hyprland keybinds and emit grouped JSON")
    parser.add_argument("--pretty", "-p", action="store_true", help="Pretty-print JSON output")
    args = parser.parse_args()

    result = build(fetch_binds())
    indent = 2 if args.pretty else None
    print(json.dumps(result, indent=indent, ensure_ascii=False))


if __name__ == "__main__":
    main()
