#!/usr/bin/env bash

request="${1:-}"
mode="${2:-}"

if [[ -z "$request" ]]; then
  echo "Usage: ai-text <prompt> [replace]" >&2
  exit 1
fi

send_notification() {
  local title="$1"
  local body="${2:-}"

  printf '%s - %s\n' "$title" "$body"
  notify-send -h "string:x-tag:ai-text" -i google-translate -u low "$title" "$body"
}

original=$(wl-paste -p)

if [[ "$mode" == "replace" ]]; then
  send_notification "$request for" "$original"
  res=$(aichat "$request: $original")
  wl-copy "$res"
  wtype -M ctrl v
  sleep 0.5
  wl-copy "$original"
  send_notification "Done!"
  exit 0
fi

send_notification "$request for:" "$original"
res=$(aichat "$request: $original")
send_notification " " "$res"
