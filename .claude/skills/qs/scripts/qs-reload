#!/usr/bin/env bash
# qs-reload — reliably trigger a quickshell hot reload (or restart qs/qs-daemon)
# and show the log tail so QML errors are visible.
#
# Why this exists: quickshell's file watcher needs inode-preserving writes.
# Editors (and Claude Code's Edit tool) that rename-on-save orphan the watch,
# so edits silently stop hot-reloading. This script rewrites a watched file
# truncate-in-place, which always triggers a reload.
#
#   qs-reload          hot reload (in-place touch of shell.qml), then log tail
#   qs-reload -r       full quickshell restart (reconstructs session env)
#   qs-reload -d       restart qs-daemon
#   qs-reload -k       refresh qs-daemon keybind cache (after hyprctl reload)
#   qs-reload -l [N]   just show the last N log lines (default 30)
set -euo pipefail

SHELL_QML="$HOME/.config/quickshell/shell.qml"
RT="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"

session_env() {
    # reconstruct the hyprland session env when run from a non-session shell
    export XDG_RUNTIME_DIR="$RT"
    export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-1}"
    export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=$RT/bus}"
    if [[ -z ${HYPRLAND_INSTANCE_SIGNATURE:-} ]]; then
        # NOT `ls` — it's icon-wrapped on this system and corrupts the name
        HYPRLAND_INSTANCE_SIGNATURE=$(find "$RT/hypr/" -maxdepth 1 -mindepth 1 -printf '%f\n' | head -1)
        export HYPRLAND_INSTANCE_SIGNATURE
    fi
}

log_tail() {
    qs log -t "${1:-30}" --no-color 2>/dev/null || echo "(no quickshell instance running?)"
}

mode=reload
lines=30
case ${1:-} in
    -r|--restart) mode=restart ;;
    -d|--daemon)  mode=daemon ;;
    -k|--keybinds) mode=keybinds ;;
    -l|--log)     mode=log; lines=${2:-30} ;;
    -h|--help) sed -n '2,15p' "$0"; exit 0 ;;
    "") ;;
    *) echo "unknown option: $1" >&2; exit 1 ;;
esac

case $mode in
    reload)
        # truncate-in-place rewrite: same content, same inode -> watcher fires
        tmp=$(mktemp)
        cat "$SHELL_QML" > "$tmp"
        cat "$tmp" > "$SHELL_QML"
        rm -f "$tmp"
        sleep 1
        echo "== hot reload triggered; log tail:"
        log_tail "$lines"
        ;;
    restart)
        session_env
        pkill -x .quickshell-wra 2>/dev/null || true   # comm is truncated wrapper name, not "quickshell"
        sleep 0.3
        setsid -f quickshell >/dev/null 2>&1
        sleep 1.5
        qs list
        echo "== log tail:"
        log_tail "$lines"
        ;;
    daemon)
        session_env
        # bracket trick so pgrep can't match this script's own cmdline
        pid=$(pgrep -f '[q]s-daemon$' || true)
        [[ -n $pid ]] && kill "$pid" && sleep 0.3
        setsid -f qs-daemon >/dev/null 2>&1
        sleep 0.8
        curl -s --max-time 2 --unix-socket "$RT/qs-daemon.sock" http://d/health | jq .
        ;;
    keybinds)
        curl -s --unix-socket "$RT/qs-daemon.sock" http://d/keybinds/reload
        echo
        ;;
    log)
        log_tail "$lines"
        ;;
esac
